[Unit]
Description=Task WebApp (FastAPI)
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/task-webapp
ExecStart=/usr/local/bin/uvicorn main:app --host 127.0.0.1 --port 8443
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/root/.env

[Install]
WantedBy=multi-user.target
